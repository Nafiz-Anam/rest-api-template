# Disable dotenv tips
DOTENV_NO_TIPS=true

# Port number
PORT=8000

# External Database Configuration (Neon/AWS RDS)
# Replace with your actual database URL
DATABASE_URL="postgresql://user:password@your-neon-db-url.neon.tech/dbname?schema=public&sslmode=require"

# JWT Configuration
# JWT secret key
JWT_SECRET=your-super-secret-jwt-key
# Number of minutes after which an access token expires
JWT_ACCESS_EXPIRATION_MINUTES=15
# Number of days after which a refresh token expires
JWT_REFRESH_EXPIRATION_DAYS=7
# Number of minutes after which a reset password token expires
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
# Number of minutes after which a verify email token expires
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# WebSocket Configuration
WS_PORT=8080

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourapp.com

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# IP Security Configuration
# Comma-separated list of whitelisted IP addresses
WHITELISTED_IPS=127.0.0.1,192.168.1.100
# Comma-separated list of blacklisted IP addresses
BLACKLISTED_IPS=192.168.1.99,10.0.0.50
# Enable geolocation-based IP filtering
ENABLE_GEOLOCATION=true
# Comma-separated list of allowed country codes (ISO 3166-1)
ALLOWED_COUNTRIES=US,CA,GB,DE
# Comma-separated list of suspicious country codes
SUSPICIOUS_COUNTRIES=CN,RU,KP,IR

# CAPTCHA Configuration
# Enable CAPTCHA protection
CAPTCHA_ENABLE=true
# CAPTCHA provider: recaptcha, hcaptcha, or custom
CAPTCHA_PROVIDER=recaptcha
# reCAPTCHA site key
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
# reCAPTCHA secret key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
# hCaptcha site key
HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
# hCaptcha secret key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key
# CAPTCHA threshold score (0.0-1.0)
CAPTCHA_THRESHOLD=0.5
